[Unit]
Description=PolyMaster FastAPI Server
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/PolyMaster/backend
EnvironmentFile=/home/ubuntu/PolyMaster/backend/.env
ExecStart=/home/ubuntu/PolyMaster/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 1
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
